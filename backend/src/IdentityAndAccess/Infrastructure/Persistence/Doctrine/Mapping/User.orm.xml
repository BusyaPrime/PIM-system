<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                          http://raw.github.com/doctrine/doctrine2/master/doctrine-mapping.xsd">

    <entity name="App\IdentityAndAccess\Domain\Entity\User" table="iam_users">
        <id name="id" type="string" length="36">
            <generator strategy="NONE"/>
        </id>

        <field name="email" type="string" length="180" unique="true" nullable="true" />
        <field name="password" type="string" length="255" nullable="true" />
        <field name="name" type="string" length="255" nullable="true" />
        <field name="emailVerified" type="boolean" />
        <field name="roles" type="json" />
        <field name="isActive" type="boolean" />

        <one-to-many target-entity="App\IdentityAndAccess\Domain\Entity\OAuthAccount" mapped-by="user" field="oauthAccounts">
            <cascade>
                <cascade-all/>
            </cascade>
        </one-to-many>

    </entity>
</doctrine-mapping>
