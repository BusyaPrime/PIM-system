<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                                      https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">

    <entity name="App\Audit\Domain\Entity\Revision" table="audit_revisions">
        <id name="id" type="string" length="36">
            <generator strategy="NONE"/>
        </id>

        <field name="entityType" type="string" length="100" />
        <field name="entityId" type="string" length="36" />
        <field name="userId" type="string" length="36" nullable="true" />
        <field name="action" type="string" length="20" />
        <field name="changes" type="json" />
        <field name="timestamp" type="datetime_immutable" />

        <indexes>
            <index name="idx_entity_type_id" columns="entity_type,entity_id" />
            <index name="idx_timestamp" columns="timestamp" />
        </indexes>
    </entity>

</doctrine-mapping>
