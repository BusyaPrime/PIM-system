<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                          http://raw.github.com/doctrine/doctrine2/master/doctrine-mapping.xsd">

    <entity name="App\Enrichment\Domain\Entity\CompletenessRule" table="enrichment_completeness_rules">
        <id name="id" type="string" length="36">
            <generator strategy="NONE"/>
        </id>

        <field name="familyId" type="string" length="36" />
        <field name="attributeId" type="string" length="36" />
        <field name="channel" type="string" length="50" nullable="true" />
        <field name="locales" type="json" />
        <field name="isRequired" type="boolean" />

        <indexes>
            <index name="idx_rule_family" columns="family_id"/>
        </indexes>
    </entity>
</doctrine-mapping>
