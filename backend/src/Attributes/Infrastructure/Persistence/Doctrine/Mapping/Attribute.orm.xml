<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                          http://raw.github.com/doctrine/doctrine2/master/doctrine-mapping.xsd">

    <entity name="App\Attributes\Domain\Entity\Attribute" table="catalog_attributes">
        <id name="id" type="string" length="36">
            <generator strategy="NONE"/>
        </id>

        <field name="code" type="string" length="255" unique="true" />
        <field name="type" type="string" length="50" />
        <field name="isLocalizable" type="boolean" />
        <field name="isScopable" type="boolean" />
        <field name="validationRules" type="json" />

    </entity>
</doctrine-mapping>
