<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping
                          http://raw.github.com/doctrine/doctrine2/master/doctrine-mapping.xsd">

    <entity name="App\Attributes\Domain\Entity\Value\AbstractAttributeValue" table="attribute_values" inheritance-type="JOINED">
        <discriminator-column name="dtype" type="string" />
        <discriminator-map>
            <discriminator-mapping value="text" class="App\Attributes\Domain\Entity\Value\TextAttributeValue" />
            <discriminator-mapping value="number" class="App\Attributes\Domain\Entity\Value\NumberAttributeValue" />
            <discriminator-mapping value="boolean" class="App\Attributes\Domain\Entity\Value\BooleanAttributeValue" />
        </discriminator-map>

        <id name="id" type="string" length="36">
            <generator strategy="NONE"/>
        </id>

        <field name="productId" type="string" length="36" />
        <field name="locale" type="string" length="10" nullable="true" />
        <field name="channel" type="string" length="50" nullable="true" />

        <many-to-one field="attribute" target-entity="App\Attributes\Domain\Entity\Attribute">
            <join-column name="attribute_id" referenced-column-name="id" on-delete="CASCADE" />
        </many-to-one>

        <indexes>
            <index name="idx_attr_values_search" columns="product_id,attribute_id,locale,channel"/>
        </indexes>
    </entity>
</doctrine-mapping>
